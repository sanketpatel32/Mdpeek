{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "mdpeek",
  "version": "0.11.9",
  "identifier": "com.mdpeek.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "mdpeek",
        "width": 1100,
        "height": 760,
        "minWidth": 640,
        "minHeight": 420,
        "decorations": false,
        "shadow": true
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": {
          "allow": ["**"]
        }
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "fileAssociations": [
      {
        "ext": ["md", "markdown", "mdx"],
        "name": "Markdown",
        "description": "Markdown document",
        "role": "Viewer",
        "mimeType": "text/markdown"
      },
      {
        "ext": ["txt"],
        "name": "Plain Text",
        "description": "Plain text document",
        "role": "Viewer",
        "mimeType": "text/plain"
      },
      {
        "ext": ["pdf"],
        "name": "PDF",
        "description": "PDF document",
        "role": "Viewer",
        "mimeType": "application/pdf"
      },
      {
        "ext": ["excalidraw"],
        "name": "Excalidraw",
        "description": "Excalidraw canvas",
        "role": "Viewer",
        "mimeType": "application/json"
      }
    ],
    "windows": {
      "nsis": {
        "installMode": "perMachine",
        "installerIcon": "icons/icon.ico",
        "installerHooks": "nsis/file-assoc.nsh"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDRENTY1QkUxOUNEMDFFMTEKUldRUkh0Q2M0VnRXVGFucXgrZ3krZmJLTU1raUE4Q0xSbXE2RUNvdFViTW5lT296R2d3UHlXUHMK",
      "endpoints": [
        "https://github.com/sanketpatel32/Mdpeek/releases/latest/download/latest.json"
      ]
    }
  }
}
