node_modules/
src-tauri/target/
dist/
.vite/

# Tauri signing private key — NEVER commit this. Keep it safe; lose it = no updates.
.tauri/*.key

# Mobile icon sets regenerated by `tauri icon` — not used by this Windows-only app.
src-tauri/icons/android/
src-tauri/icons/ios/

# Local release artifacts — the canonical copies live on GitHub Releases.
# Ignore all built installers/signatures/manifests so they never bloat the repo.
releases/

# Scratch / work-in-progress assets not part of the shipped app:
#   - logo + app-icon concept SVGs
#   - dev screenshots
#   - unrelated data files (e.g. tesseract traineddata)
logo-concept-*.svg
logo-ootb-*.svg
app-icon-*-concept.svg
v0*_preview.png
v0*-full-preview.png
v0*-full.png
.zcode/v0*.png
eng.traineddata

